# TrendSeer Configuration
# Copy this file to .env and fill in your values

# GitHub API token (optional, increases rate limits)
GITHUB_TOKEN=

# Hacker News API (no auth needed, but you can set custom base URL)
HN_API_BASE=https://hacker-news.firebaseio.com/v0

# RSS feed URLs (comma-separated)
RSS_FEEDS=https://hnrss.org/newest,https://www.reddit.com/r/technology/.rss

# Anomaly detection thresholds
ZSCORE_THRESHOLD=2.0
ROLLING_WINDOW_SIZE=7

# Export settings
EXPORT_FORMAT=json
EXPORT_DIR=./output

# Logging
LOG_LEVEL=INFO
